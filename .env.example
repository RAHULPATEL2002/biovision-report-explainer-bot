# BioVision Bot environment variables
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env`.

# App mode
APP_ENV=production
APP_URL=https://your-app.railway.app
PAYMENT_CALLBACK_URL=https://your-app.railway.app/payment-success

# WhatsApp Cloud API
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=biovision2025

# AI
# Recommended for production: Anthropic
# Free local alternative: set AI_PROVIDER=ollama
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# OCR
# Recommended for production: Google Vision
# Free local alternative: set OCR_PROVIDER=tesseract
OCR_PROVIDER=google_vision
GOOGLE_VISION_API_KEY=AIza_your_key_here
TESSERACT_CMD=tesseract

# Payments
PAYMENTS_ENABLED=true
FREE_REPORT_LIMIT=3
RAZORPAY_KEY_ID=rzp_live_or_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Processing
PROCESSING_CONCURRENCY=3

# Database
# Local: biovision.db
# Railway with volume: /data/biovision.db
SQLITE_DB_PATH=biovision.db
