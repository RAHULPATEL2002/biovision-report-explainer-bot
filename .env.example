# BioVision Bot environment variables
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env`.

APP_ENV=production
APP_URL=https://your-app.railway.app
ADMIN_API_KEY=replace_with_a_long_random_secret

# WhatsApp Cloud API
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=biovision2025

# AI
# Recommended current setup: OpenRouter
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your_key_here
AI_MODEL=openrouter/free

# Optional alternatives
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# OCR
OCR_PROVIDER=google_vision
GOOGLE_VISION_API_KEY=AIza_your_key_here
TESSERACT_CMD=tesseract

# Payments
# Best current default for this build: direct UPI payment + manual approval
PAYMENTS_ENABLED=true
PAYMENT_PROVIDER=upi_manual
FREE_REPORT_LIMIT=3
REPORT_PRICE_INR=30
UPI_VPA=yourupiid@bank
UPI_PAYEE_NAME=BioVision

# Optional Razorpay config if you switch later
PAYMENT_CALLBACK_URL=https://your-app.railway.app/payment-success
RAZORPAY_KEY_ID=rzp_live_or_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Processing
PROCESSING_CONCURRENCY=3

# Database
SQLITE_DB_PATH=biovision.db
